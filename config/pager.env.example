# User/group that should own runtime files
PAGER_USER=daniel
PAGER_GROUP=daniel
WORKDIR=/home/daniel

# SDR tuning
RTL_DEVICE=0
RTL_FREQUENCY=148.7125M
RTL_SAMPLE_RATE=22050
RTL_GAIN=
RTL_AGC_MODE=fast
RTL_ERROR_LOG=/var/lib/pager/rtl_fm.err

# Decoder modes
POCSAG_MODES=POCSAG512 POCSAG1200 POCSAG2400
MULTIMON_BATCH=1

# Filtering / shared output
DEDUP_WINDOW=60
LOG_DIR=/var/lib/pager
LOG_FILE=/var/lib/pager/messages.log
HEALTH_FILE=/var/lib/pager/health.json
RESTART_DELAY=1

# Web metadata
WEB_ROOT=/var/www/pager-ui
WEB_PORT=8000
